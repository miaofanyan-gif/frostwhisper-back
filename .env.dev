# --- 基础项目配置 ---
PROJECT_NAME="Frostwhisper Hanfu (Dev)"
VERSION="1.0.0"
ENV="dev"
API_V1_STR="/api/v1"

# --- 数据库配置 (MySQL 8.0 + asyncmy) ---  
# 格式: mysql+asyncmy://用户名:密码@地址:端口/数据库名
MYSQL_URL="mysql+pymysql://root:123456@localhost:3306/frostwhisper_hanfu"

# --- 缓存配置 (Redis 7) ---
# 格式: redis://:密码@地址:端口/数据库编号
REDIS_URL="redis://127.0.0.1:6379/0"

# --- 安全与加密 (JWT) ---
# 提示: 开发环境可以使用简单的密钥，生产环境必须更换
SECRET_KEY="C_ylfBdxTXjtBH_m4ErmmrEpIDef-oz4obCh3oj9ZOk="
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=1440  # 24小时

# --- 跨境业务配置 ---
DEFAULT_CURRENCY="CNY"
SUPPORTED_CURRENCIES=["CNY", "USD", "EUR", "JPY"]

# --- 跨域配置 (CORS) ---
# 开发环境允许所有来源
CORS_ORIGINS=["http://localhost:3000", "http://127.0.0.1:3000"]

URL=http://www.bestecho.asia/